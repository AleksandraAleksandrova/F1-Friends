rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isLeagueAdmin(leagueId) {
      return signedIn() &&
        get(/databases/$(database)/documents/leagues/$(leagueId)).data.adminUserId == request.auth.uid;
    }

    match /users/{uid} {
      allow create, read, update: if signedIn() && request.auth.uid == uid;
      allow delete: if false;
    }
 
    match /leagues/{leagueId} {
      allow create: if signedIn() &&
        request.resource.data.adminUserId == request.auth.uid &&
        request.resource.data.memberIds is list &&
        request.resource.data.memberIds.size() > 0 &&
        request.auth.uid in request.resource.data.memberIds;

      // Leagues are private. Allow direct read only if caller has membership doc.
      allow get: if signedIn() &&
        exists(/databases/$(database)/documents/leagues/$(leagueId)/members/$(request.auth.uid));
      allow list: if false;

      // Temporary pragmatic rule for client-side prototype flows:
      // authenticated users can update league docs (join/member counters).
      // Move this to Cloud Functions for stricter production control.
      allow update: if signedIn();

      allow delete: if isLeagueAdmin(leagueId);
    }

    match /leagues/{leagueId}/members/{memberId} {
      // User can read only their own membership documents.
      // This supports collectionGroup("members").where("userId", "==", uid).
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create, update: if signedIn() &&
        (
          (request.auth.uid == memberId &&
            request.resource.data.userId == request.auth.uid) ||
          isLeagueAdmin(leagueId)
        );
      allow delete: if isLeagueAdmin(leagueId);
    }

    match /leagueJoinCodes/{joinCode} {
      allow get: if signedIn();
      allow create: if signedIn();
      allow update, delete, list: if false;
    }

    // Keep other collections private by default until explicitly implemented.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

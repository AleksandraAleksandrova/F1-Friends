rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isLeagueAdmin(leagueId) {
      return signedIn() &&
        get(/databases/$(database)/documents/leagues/$(leagueId)).data.adminUserId == request.auth.uid;
    }

    match /users/{uid} {
      // Public read needed for username -> email lookup at login.
      allow read: if true;
      allow create, update, delete: if signedIn() && request.auth.uid == uid;
    }

    match /usernames/{usernameLower} {
      allow read: if true;
      allow create, update, delete: if signedIn();
    }
 
    match /leagues/{leagueId} {
      allow read: if signedIn();
      allow create: if signedIn() &&
        request.resource.data.adminUserId == request.auth.uid;
      allow update: if signedIn();
      allow delete: if isLeagueAdmin(leagueId);
    }

    match /leagues/{leagueId}/members/{memberId} {
      allow read: if signedIn();
      allow create, update: if signedIn();
      allow delete: if isLeagueAdmin(leagueId);
    }

    match /leagueJoinCodes/{joinCode} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if signedIn();
    }

    match /predictions/{predictionId} {
      allow read: if signedIn();
      allow create, update: if signedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /races/{raceId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /raceResults/{raceId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /leagueScores/{leagueId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /notifications/{notificationId} {
      allow read: if signedIn();
      allow write: if false;
    }

    // Demo mode: allow authenticated read visibility across the app to avoid
    // brittle query denials while features are still being built.
    match /{document=**} {
      allow read: if signedIn();
      allow write: if false;
    }
  }
}

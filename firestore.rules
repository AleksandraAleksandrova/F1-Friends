rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isLeagueAdmin(leagueId) {
      return signedIn() &&
        get(/databases/$(database)/documents/leagues/$(leagueId)).data.adminUserId == request.auth.uid;
    }

    function isLeagueMember(leagueId) {
      return signedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/leagues/$(leagueId)).data.memberIds;
    }

    match /users/{uid} {
      allow create, read, update: if signedIn() && request.auth.uid == uid;
      allow delete: if false;
    }

    match /leagues/{leagueId} {
      allow create: if signedIn() &&
        request.resource.data.adminUserId == request.auth.uid &&
        request.resource.data.memberIds is list &&
        request.resource.data.memberIds.size() > 0 &&
        request.auth.uid in request.resource.data.memberIds;

      allow read: if isLeagueMember(leagueId);

      // Temporary pragmatic rule for client-side prototype flows:
      // authenticated users can update league docs (join/member counters).
      // Move this to Cloud Functions for stricter production control.
      allow update: if signedIn();

      allow delete: if isLeagueAdmin(leagueId);
    }

    match /leagues/{leagueId}/members/{memberId} {
      allow read: if isLeagueMember(leagueId);
      allow create, update: if signedIn() &&
        (request.auth.uid == memberId || isLeagueAdmin(leagueId));
      allow delete: if isLeagueAdmin(leagueId);
    }

    // Keep other collections private by default until explicitly implemented.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

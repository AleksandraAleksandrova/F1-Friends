rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isLeagueAdmin(leagueId) {
      return signedIn() &&
        get(/databases/$(database)/documents/leagues/$(leagueId)).data.adminUserId == request.auth.uid;
    }

    match /users/{uid} {
      allow create, read, update, delete: if signedIn() && request.auth.uid == uid;
    }
 
    match /leagues/{leagueId} {
      // Dev-friendly read access for authenticated users to avoid fragile query denials.
      allow read: if signedIn();

      allow create: if signedIn() &&
        request.resource.data.adminUserId == request.auth.uid;

      // Client currently updates member counters + ids directly.
      allow update: if signedIn();

      allow delete: if isLeagueAdmin(leagueId);
    }

    match /leagues/{leagueId}/members/{memberId} {
      // Relaxed read avoids collection/group query permission edge-cases.
      allow read: if signedIn();
      allow create, update: if signedIn() &&
        (
          (request.auth.uid == memberId &&
            request.resource.data.userId == request.auth.uid) ||
          isLeagueAdmin(leagueId)
        );
      allow delete: if isLeagueAdmin(leagueId);
    }

    match /leagueJoinCodes/{joinCode} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if false;
    }

    match /predictions/{predictionId} {
      // Read enabled for authenticated users to avoid repeated query/get denials.
      allow read: if signedIn();
      allow create, update: if signedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    // Keep unimplemented collections private.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
